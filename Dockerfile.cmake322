FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        git \
        libssl-dev \
        make \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

CMD ["cmake", "--version"]
